{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tasks.schema.json",
  "title": "Parallel Task System Schema",
  "description": "Schema for the shared task list in the parallel multi-agent system",
  "type": "object",
  "required": ["version", "tasks"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "lastUpdated": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Task"
      }
    }
  },
  "definitions": {
    "Task": {
      "type": "object",
      "required": ["task_id", "title", "status", "priority"],
      "properties": {
        "task_id": {
          "type": "string",
          "description": "Unique task identifier (TASK-XXX)",
          "pattern": "^TASK-\\d{3}$"
        },
        "title": {
          "type": "string",
          "description": "Short descriptive title"
        },
        "description": {
          "type": "string",
          "description": "Detailed task description"
        },
        "assigned_agent": {
          "type": ["string", "null"],
          "enum": [null, "team-lead", "backend", "frontend", "ui", "qa", "security", "performance", "reviewer"],
          "description": "Agent assigned to this task"
        },
        "status": {
          "type": "string",
          "enum": ["backlog", "claimed", "working", "completed"],
          "description": "Current task status"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^TASK-\\d{3}$"
          },
          "description": "Task IDs that must complete before this task"
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "Task priority level"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Files created or modified by this task"
        },
        "created_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When the task was created"
        },
        "claimed_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When an agent claimed the task"
        },
        "completed_at": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "When the task was completed"
        },
        "feature_id": {
          "type": ["string", "null"],
          "description": "Parent feature ID (FEAT-XXX)"
        }
      }
    }
  }
}
