{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "agents.schema.json",
  "title": "Agents State",
  "description": "Schema for tracking agent status in the AI development system",
  "type": "object",
  "required": ["version", "agents"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "lastUpdated": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "agents": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/AgentState"
      }
    }
  },
  "definitions": {
    "AgentState": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["idle", "working", "blocked", "waiting", "error", "offline"],
          "description": "Current agent status"
        },
        "currentTask": {
          "type": ["string", "null"],
          "description": "Task ID currently being worked on"
        },
        "currentFeature": {
          "type": ["string", "null"],
          "description": "Feature ID currently contributing to"
        },
        "lastActivity": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "Timestamp of last activity"
        },
        "lastAction": {
          "type": ["string", "null"],
          "description": "Description of last action performed"
        },
        "completedTasks": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of completed tasks"
        },
        "blockedReason": {
          "type": ["string", "null"],
          "description": "Reason if status is blocked"
        },
        "waitingFor": {
          "type": ["string", "null"],
          "description": "Agent or resource being waited on"
        },
        "errorMessage": {
          "type": ["string", "null"],
          "description": "Error message if status is error"
        },
        "workingDirectory": {
          "type": ["string", "null"],
          "description": "Current directory being modified"
        },
        "progress": {
          "type": "object",
          "properties": {
            "current": {
              "type": "integer",
              "minimum": 0
            },
            "total": {
              "type": "integer",
              "minimum": 0
            },
            "percentage": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          },
          "description": "Progress on current task"
        }
      }
    }
  }
}
