    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "jest": "^29.0.0",
    "jsdom": "^28.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
